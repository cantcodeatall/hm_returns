# ── Housemartin Account Credentials ─────────────────────────────────────────
# Rename this file to .env and fill in your details.
# Never commit .env to version control.

HM_ACCOUNT1_NAME=Your Name
HM_ACCOUNT1_EMAIL=you@example.com
HM_ACCOUNT1_PASSWORD=yourpassword

HM_ACCOUNT2_NAME=Partner Name
HM_ACCOUNT2_EMAIL=partner@example.com
HM_ACCOUNT2_PASSWORD=partnerpassword

HM_ACCOUNT3_NAME=Child Name
HM_ACCOUNT3_EMAIL=child@example.com
HM_ACCOUNT3_PASSWORD=childpassword

# ── Optional settings ─────────────────────────────────────────────────────────

# Benchmark ETF tickers, comma-separated (defaults shown below)
# VWRP.L = Global equities | XDER.L = European property | SLXX.L = Corp bonds
ETF_TICKERS=VWRP.L,XDER.L,SLXX.L

# Where your browser downloads files (default: ~/Downloads)
# DOWNLOAD_DIR=C:\Users\YourName\Downloads
