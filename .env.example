# ── Housemartin account credentials ──────────────────────────────────────────
# Add one block per account holder. Accounts with blank credentials are skipped.
# Passwords containing special characters (e.g. $) should be wrapped in single quotes.

HM_ACCOUNT1_NAME=Account1
HM_ACCOUNT1_EMAIL=account1@example.com
HM_ACCOUNT1_PASSWORD=yourpassword

HM_ACCOUNT2_NAME=Account2
HM_ACCOUNT2_EMAIL=account2@example.com
HM_ACCOUNT2_PASSWORD=yourpassword

HM_ACCOUNT3_NAME=Account3
HM_ACCOUNT3_EMAIL=account3@example.com
HM_ACCOUNT3_PASSWORD=yourpassword

# ── Benchmark ETFs ────────────────────────────────────────────────────────────
# Comma-separated Yahoo Finance tickers.
ETF_TICKERS=VWRP.L,XDER.L,VAGS.L

# Display labels for each ticker — must match ETF_TICKERS exactly.
# Format: TICKER=Label, comma-separated, no quotes.
ETF_LABELS=VWRP.L=Global Equities (VWRP),XDER.L=European Property (XDER),VAGS.L=Global Bonds (VAGS)

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Results are pushed automatically after every run.
# The sheet must already exist; share it with the service account email (Editor).
# The Sheet ID is the long string in your sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_PART/edit
GSHEET_ID=your_google_sheet_id_here
GSHEET_SHEET_NAME=HM
GSHEET_KEY_FILE=service_account.json

# ── Portfolio Performance ─────────────────────────────────────────────────────
# Sub-account types to generate PP data for (comma-separated).
# Use the same suffixes that appear in your hm_staging/ CSV filenames.
PP_ACCOUNT_TYPES=reg,isa

# Optional: override the PP securities account name prefix per account holder.
# Default if not set: "{HM_ACCOUNTn_NAME} HM" (e.g. "Account1 HM Reg")
# Set these if you want shorter or different names in Portfolio Performance.
PP_ACCOUNT1_PP_NAME=Account1 HM
PP_ACCOUNT2_PP_NAME=Account2 HM
PP_ACCOUNT3_PP_NAME=Account3 HM

# PP NAV series dates — set once, do not change after the seed has been run.
# STARTING_DATE: the date NAV=100. Use the start of your investment history.
# SPLIT_DATE:    first date that per-account values appear in hm_history.csv
#                (check the file for the first row with per-account columns filled).
PP_STARTING_DATE=2023-01-01
PP_SPLIT_DATE=2026-03-14
